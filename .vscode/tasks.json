{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "label": "npm: watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^✘ \\[ERROR\\] (.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*\\[watch\\].*$",
          "endsPattern": "^.*\\[watch\\] build finished.*$"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "group": "herdr-build"
      }
    },
    {
      "type": "npm",
      "script": "build",
      "label": "npm: build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "group": "herdr-build"
      }
    },
    {
      "type": "npm",
      "script": "check",
      "label": "npm: check",
      "group": "test",
      "problemMatcher": "$tsc"
    },
    {
      "type": "npm",
      "script": "test",
      "label": "npm: test",
      "group": "test",
      "problemMatcher": "$tsc"
    }
  ]
}
